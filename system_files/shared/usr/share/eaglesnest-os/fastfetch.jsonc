    },
    {
      "type": "display",
      "key": "¾░ı╣ ¯éÁ Display"
    },
    {
      "type": "battery",
      "key": "´ëé ¯éÁ Battery"
    },
    {
      "type": "gamepad",
      "key": "¾░û║ ¯éÁ Gamepad"
    },
    "break",
    {
