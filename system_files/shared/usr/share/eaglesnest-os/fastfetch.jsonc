      "key": "´Æê ¯éÁ WM"
    },
    {
      "type": "shell",
      "key": "´Æë ¯éÁ Shell",
      "format": "{1} {4}"
    },
    {
      "type": "terminal",
      "key": "¯Şò ¯éÁ Terminal"
    },
    {
