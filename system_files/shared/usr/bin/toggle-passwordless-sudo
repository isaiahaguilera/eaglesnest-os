#!/usr/bin/bash
# Toggle passwordless sudo for the current user
#
# Creates or removes a sudoers drop-in file that grants NOPASSWD access.
# Uses /etc/sudoers.d/ which persists across image updates on bootc systems.
#
# Usage: sudo toggle-passwordless-sudo
#
# Security note: This is a convenience feature for home/development systems.
# Enabling passwordless sudo reduces security - use with caution.

if [ "$EUID" -ne 0 ]; then
    echo "Error: Must run with sudo"
    exit 1
fi

SUDOERS_FILE="/etc/sudoers.d/99-passwordless"

# $SUDO_USER is set by sudo to the invoking user, more reliable than $USER
TARGET_USER="${SUDO_USER:-$USER}"

if [ -z "$TARGET_USER" ]; then
    echo "Error: Could not determine user"
    exit 1
fi

if [ -f "$SUDOERS_FILE" ]; then
    rm "$SUDOERS_FILE"
    echo "Passwordless sudo DISABLED for $TARGET_USER"
else
    echo "$TARGET_USER ALL=(ALL) NOPASSWD: ALL" > "$SUDOERS_FILE"
    chmod 440 "$SUDOERS_FILE"
    echo "Passwordless sudo ENABLED for $TARGET_USER"
fi
