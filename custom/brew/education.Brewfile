# Education / homeschool CLI tools (Homebrew)
#
# Add packages with: brew "package-name"
# Install on a deployed machine via: ujust install-education
#
# Candidates to consider:
#   brew "tldr"          # Simplified man pages, great for learners
#   brew "cmatrix"       # Terminal eye-candy
#   brew "asciinema"     # Record terminal sessions for show-and-tell
#   brew "fortune"       # Quotes / programming wisdom
#   brew "cowsay"        # Fun text decoration
